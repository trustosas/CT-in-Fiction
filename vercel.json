{
  "rewrites": [
    {
      "source": "/va/script.js",
      "destination": "/_vercel/insights/script.js"
    },
    {
      "source": "/va/view",
      "destination": "/_vercel/insights/view"
    },
    {
      "source": "/va/event",
      "destination": "/_vercel/insights/event"
    },
    {
      "source": "/vsi/script.js",
      "destination": "/_vercel/speed-insights/script.js"
    },
    {
      "source": "/vsi",
      "destination": "/_vercel/speed-insights/v1"
    },
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
